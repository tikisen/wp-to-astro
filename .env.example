# WordPress site to migrate
WP_SITE_URL=https://example.com
# Format: username:xxxx xxxx xxxx xxxx xxxx xxxx
# Generate: WP Admin → Users → Edit → Application Passwords → Add New
WP_APP_PASSWORD=admin:xxxx xxxx xxxx xxxx xxxx xxxx

# Output site name (repo will be <SITE_NAME>-astro)
SITE_NAME=example

# Firecrawl
FIRECRAWL_API_KEY=fc-...

# Cloudflare
CF_API_TOKEN=...
CF_ACCOUNT_ID=...

# GTM (optional — leave blank to skip GTM setup)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Formbricks
FORMBRICKS_URL=https://forms.goodbusiness.us
FORMBRICKS_API_KEY=...

# Notion
NOTION_TOKEN=...
NOTION_WORKSPACE=tsg
